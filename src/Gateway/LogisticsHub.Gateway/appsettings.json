{
  "ReverseProxy": {
    "Routes": {
      "shipment-route": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/shipment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/shipment"
          }
        ]
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/inventory/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/inventory"
          }
        ]
      }
    },
    "Clusters": {
      "shipment-cluster": {
        "Destinations": {
          "shipment-destination": {
            "Address": "http://localhost:5102/"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-destination": {
            "Address": "http://localhost:5101/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*"
}